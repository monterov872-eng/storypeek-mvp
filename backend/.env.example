PORT=3001

# Use web provider for MVP (free, public accounts only)
INSTAGRAM_PROVIDER=web

# ---------------------------------------------------------------------------
# SERVER-ONLY SESSION (local testing) — NEVER commit .env, NEVER put in mobile app
# ---------------------------------------------------------------------------
# 1. Log into instagram.com in desktop Chrome/Edge (use a throwaway test account)
# 2. DevTools → Application → Cookies → https://www.instagram.com → sessionid
# 3. Copy the Value into backend/.env (this file is gitignored):
#
# INSTAGRAM_SESSION_ID=paste_sessionid_value_here
#
# Full guide: backend/docs/SESSION_SETUP.md
# ---------------------------------------------------------------------------

# INSTAGRAM_APP_ID=936619743392459
# INSTAGRAM_REQUEST_TIMEOUT_MS=12000
# INSTAGRAM_REQUEST_RETRY_COUNT=2
# INSTAGRAM_REQUEST_RETRY_DELAY_MS=1500
# INSTAGRAM_PROFILE_CACHE_TTL_MS=600000
# INSTAGRAM_MEDIA_CACHE_TTL_MS=300000
# INSTAGRAM_SEARCH_COOLDOWN_MS=20000

# Integration test usernames (optional) — npm run test:integration
# TEST_PUBLIC_USERNAME=natgeo
# TEST_PRIVATE_USERNAME=your_known_private_account
# TEST_NO_STORIES_USERNAME=public_account_with_no_active_story

# --- Paid provider later (INSTAGRAM_PROVIDER=rest) ---
# INSTAGRAM_REST_BASE_URL=https://your-proxy.example.com/v1
# INSTAGRAM_REST_API_KEY=
# INSTAGRAM_REST_AUTH_HEADER=x-api-key

# ---------------------------------------------------------------------------
# RapidAPI — Instagram Scraper Stable API (server-only, never in mobile app)
# Subscribe: https://rapidapi.com/thetechguy32744/api/instagram-scraper-stable-api
# ---------------------------------------------------------------------------
# RAPID_API_KEY=your_rapidapi_key_here
# RAPID_API_TIMEOUT_MS=20000
# RAPID_API_HIGHLIGHTS_PATH=/get_ig_user_highlights.php

# ---------------------------------------------------------------------------
# RapidAPI — Highlight stories only (separate product; server-only)
# Used when opening a highlight. Stable API above stays for stories + highlight list.
# Example hosts: instagram-data14.p.rapidapi.com, instagram-scraper-api2.p.rapidapi.com
# ---------------------------------------------------------------------------
# RAPID_HIGHLIGHT_API_HOST=instagram-data14.p.rapidapi.com
# RAPID_HIGHLIGHT_API_KEY=your_rapidapi_key_here
# RAPID_HIGHLIGHT_STORIES_PATH=/get_ig_user_highlights.php
